# Copier ce fichier en .env.local et remplir avec les vraies valeurs
# (récupérables dans Vercel → Settings → Environment Variables)

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=https://VOTRE-PROJET.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...            # clé "anon public" (Settings → API)
SUPABASE_SERVICE_ROLE_KEY=eyJ...                # clé "service_role" (SECRET, serveur uniquement)

# ── Resend (emails) ──
RESEND_API_KEY=re_...                           # clé du compte Resend où maisonlocht.com est vérifié

# ── Site ──
NEXT_PUBLIC_SITE_URL=https://prevente.maisonlocht.com

# ── Admin ──
ADMIN_EMAILS=ml@maisonlocht.com,dimitrikarel77@gmail.com   # liste blanche d'accès admin
ADMIN_NOTIFY_EMAIL=ml@maisonlocht.com                       # reçoit les notifs de nouvelle commande

# ── Test (optionnel) ──
# Si défini, TOUS les emails sont redirigés ici (mode test). Retirer en production.
# RESEND_TEST_EMAIL=ton-email@gmail.com
